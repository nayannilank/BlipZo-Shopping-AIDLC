{
  "expo": {
    "name": "BlipZo",
    "slug": "blipzo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.blipzo.mobile"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.blipzo.mobile"
    },
    "plugins": ["expo-secure-store"]
  }
}

{
  "name": "blipzo",
  "private": true,
  "version": "0.0.0",
  "description": "BlipZo cloud-native e-commerce platform monorepo",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "infra/*",
    "tests/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test:unit": "turbo run test:unit",
    "test:property": "turbo run test:property",
    "test:integration": "turbo run test:integration",
    "generate:splash": "node scripts/generate-splash.mjs",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-import-x": "^4.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.19.0"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,jsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}

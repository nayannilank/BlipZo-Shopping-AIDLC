{
  "ui": "tui",
  "globalDependencies": ["tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": []
    },
    "lint": {
      "inputs": ["src/**", "eslint.config.*", ".eslintrc.*", "package.json"],
      "outputs": []
    },
    "test:unit": {
      "inputs": ["src/**", "tsconfig.json", "package.json", "vitest.config.*", "jest.config.*"],
      "outputs": ["coverage/**"]
    },
    "test:property": {
      "inputs": ["src/**", "tsconfig.json", "package.json", "vitest.config.*", "jest.config.*"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}

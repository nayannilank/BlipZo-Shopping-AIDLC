{
  "name": "@blipzo/shared",
  "version": "0.0.1",
  "description": "Shared TypeScript types, Zod schemas, and API contracts for BlipZo platform",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@middy/core": "^5.5.0",
    "zod": "^4.4.3"
  }
}
